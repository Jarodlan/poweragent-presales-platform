# Project-local RAGFlow deployment for PowerAgent
# Copy to .env before startup.

DOC_ENGINE=elasticsearch
COMPOSE_PROFILES=${DOC_ENGINE}

STACK_VERSION=8.11.3
ES_HOST=es01
ES_PORT=1201
ELASTIC_PASSWORD=infini_rag_flow

KIBANA_PORT=6602
KIBANA_USER=rag_flow
KIBANA_PASSWORD=infini_rag_flow

MEM_LIMIT=8589934592

INFINITY_HOST=infinity
INFINITY_THRIFT_PORT=23827
INFINITY_HTTP_PORT=23830
INFINITY_PSQL_PORT=5433

MYSQL_PASSWORD=infini_rag_flow
MYSQL_HOST=mysql
MYSQL_DBNAME=rag_flow
MYSQL_PORT=3306
MYSQL_EXPOSE_PORT=5456

MINIO_HOST=minio
MINIO_CONSOLE_PORT=9003
MINIO_PORT=9002
MINIO_USER=rag_flow
MINIO_PASSWORD=infini_rag_flow

REDIS_HOST=redis
REDIS_PORT=6380
REDIS_PASSWORD=infini_rag_flow

# Main service port used by PowerAgent integration.
SVR_HTTP_PORT=9381

# Official latest stable release as verified on 2026-03-20.
RAGFLOW_IMAGE=infiniflow/ragflow:v0.24.0

TIMEZONE=Asia/Shanghai
MACOS=1
HF_ENDPOINT=
