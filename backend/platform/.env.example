DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
# PostgreSQL is the default platform database for local development.
POSTGRES_NAME=power_agent
POSTGRES_USER=power_agent
POSTGRES_PASSWORD=power_agent
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
REDIS_URL=redis://127.0.0.1:6379/0
AGENT_SERVICE_BASE_URL=http://127.0.0.1:9100
PLATFORM_BASE_URL=http://127.0.0.1:8000
# Keep SQLite disabled unless PostgreSQL is temporarily unavailable.
DJANGO_USE_SQLITE=false
DJANGO_SQLITE_PATH=

CUSTOMER_DEMAND_ASR_PROVIDER=qwen
CUSTOMER_DEMAND_QWEN_ASR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CUSTOMER_DEMAND_QWEN_ASR_API_KEY=
CUSTOMER_DEMAND_QWEN_ASR_MODEL=qwen3-asr-flash
CUSTOMER_DEMAND_QWEN_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CUSTOMER_DEMAND_QWEN_LLM_API_KEY=
CUSTOMER_DEMAND_QWEN_LLM_MODEL=qwen-plus
CUSTOMER_DEMAND_FUNASR_BASE_URL=
CUSTOMER_DEMAND_FUNASR_MODE=2pass
